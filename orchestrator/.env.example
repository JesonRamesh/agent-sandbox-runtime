# Copy to `.env` and fill in real values. The actual `.env` is gitignored
# (see top-level .gitignore) — never commit credentials.

# OpenAI-compatible LLM endpoint. The default in the demo agent points at
# Cisco's outshift llm-proxy; any compatible /v1/chat/completions endpoint
# works.
OPENAI_BASE_URL=https://llm-proxy.dev.outshift.ai/

# API key. Format depends on the provider — for the outshift proxy this
# is an "sk-" style token. Required.
OPENAI_API_KEY=sk-REPLACE_ME

# Model the demo_agent / run_llm_agent scripts ask the proxy for.
LLM_MODEL=azure/gpt-5.4

# Where the relay's WebSocket sender endpoint lives. The orchestrator
# connects here as a sender to publish session_start / tool_call /
# tool_result / agent_output events that the dashboard's workflow tab
# graphs. Loopback inside the VM by default.
VIEWER_WS=ws://127.0.0.1:8765
