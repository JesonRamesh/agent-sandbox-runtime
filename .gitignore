# --- Build artefacts -------------------------------------------------
/bin/
/dist/
*.exe
*.test
*.out

# eBPF outputs (compiled by `make -C bpf`)
bpf/*.bpf.o
bpf/vmlinux.h

# Stray top-level Go-build outputs (in case someone runs `go build` directly)
/agentctl
/agentd
/test-client

# Generated bpf2go sources (when we add CO-RE generation)
internal/bpf/*_bpfel.go
internal/bpf/*_bpfeb.go
internal/bpf/*_bpfel.o
internal/bpf/*_bpfeb.o

# --- Language ecosystems --------------------------------------------
# Go
vendor/
*.cover
coverage.txt

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Node — the viewer ships two npm projects
viewer/server/node_modules/
viewer/viewer-app/node_modules/
viewer/viewer-app/dist/

# --- Vendored upstream (kept out of the tree) -----------------------
vendor/tetragon/

